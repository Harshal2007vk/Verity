{
  "name": "Candidate",
  "type": "object",
  "properties": {
    "full_name": {
      "type": "string",
      "description": "Full name of the candidate"
    },
    "current_title": {
      "type": "string",
      "description": "Current job title"
    },
    "current_company": {
      "type": "string",
      "description": "Current company"
    },
    "total_experience_years": {
      "type": "number",
      "description": "Total years of experience"
    },
    "location": {
      "type": "string",
      "description": "Location"
    },
    "resume_text": {
      "type": "string",
      "description": "Full raw resume text"
    },
    "skills_claimed": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Skills extracted from resume"
    },
    "work_history": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "company": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "start_date": {
            "type": "string"
          },
          "end_date": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "description": "Work history entries"
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "degree": {
            "type": "string"
          },
          "institution": {
            "type": "string"
          },
          "year": {
            "type": "string"
          }
        }
      },
      "description": "Education entries"
    },
    "evidence_links": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string",
            "enum": [
              "github",
              "portfolio",
              "certificate",
              "publication"
            ]
          },
          "url": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "description": "Evidence/proof links"
    },
    "behavioral_signals": {
      "type": "object",
      "properties": {
        "profile_completeness_score": {
          "type": "number"
        },
        "last_active_date": {
          "type": "string"
        },
        "response_rate": {
          "type": "number"
        },
        "application_velocity": {
          "type": "number"
        },
        "endorsement_count": {
          "type": "number"
        }
      },
      "description": "Behavioral signal data"
    },
    "candidate_intelligence": {
      "type": "object",
      "description": "AI-generated candidate intelligence",
      "properties": {
        "skill_graph": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "skill": {
                "type": "string"
              },
              "confidence": {
                "type": "number"
              },
              "source": {
                "type": "string",
                "enum": [
                  "claimed",
                  "evidenced"
                ]
              }
            }
          }
        },
        "career_trajectory_summary": {
          "type": "string"
        },
        "transferable_skills": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "growth_signal": {
          "type": "string"
        }
      }
    },
    "trust_breakdown": {
      "type": "object",
      "description": "AI-generated trust verification audit \u2014 credibility analysis of candidate claims vs evidence",
      "properties": {
        "trust_score": {
          "type": "number",
          "description": "Trust score 0-100"
        },
        "risk_level": {
          "type": "string",
          "enum": [
            "low",
            "medium",
            "high"
          ],
          "description": "Risk assessment based on claim verification"
        },
        "risk_rationale": {
          "type": "string",
          "description": "One-line rationale for the risk level"
        },
        "claims": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "claim": {
                "type": "string"
              },
              "status": {
                "type": "string",
                "enum": [
                  "supported",
                  "plausible",
                  "unsupported"
                ]
              },
              "reasoning": {
                "type": "string"
              }
            }
          }
        },
        "suspicious_patterns": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "summary": {
          "type": "string"
        }
      }
    }
  },
  "required": [
    "full_name"
  ]
}