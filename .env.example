# Gemini API for AI components
GEMINI_API_KEY="your_gemini_api_key_here"

# Groq API for additional AI tasks
GROQ_API_KEY="your_groq_api_key_here"

# Database Connection (Supabase/Postgres)
# Example: postgresql://postgres.xxxxxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host:port/database"

# Supabase Storage (Optional but recommended for PDF resumes)
# Used for storing and retrieving resume files
SUPABASE_URL="https://xxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Backend Server Port
PORT=5000
